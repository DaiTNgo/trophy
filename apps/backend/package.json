{
  "name": "backend",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "seed:admin": "node ./scripts/seed-admin.mjs",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "studio": "dizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@pdf-lib/fontkit": "^1.1.1",
    "@trophy/customization": "workspace:*",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "opentype.js": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/node": "^26.0.0",
    "@types/opentype.js": "^1.3.10",
    "drizzle-kit": "^0.31.10",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
