{
  "name": "backend",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "analyze": "ANALYZE_BUNDLE=1 vp build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "studio": "dizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@trophy/customization": "workspace:*",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "rollup-plugin-visualizer": "^7.0.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@types/node": "^26.0.1",
    "@types/opentype.js": "^1.3.10",
    "drizzle-kit": "^0.31.10",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  }
}
