prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$path='backend\\app\\seed.py'; $text=[System.IO.File]::ReadAllText((Resolve-Path $path)); $pattern='def find_asset_workbook\\(name_part: str\\) -> Path \\| None:\\s+for path in ASSET_DIR\\.glob\\(\"\\*\\.xlsx\"\\):\\s+if name_part\\.lower\\(\\) in path\\.name\\.lower\\(\\):\\s+return path\\s+return None'; $replacement='def find_asset_workbook(name_part: str) -> Path | None:' + [Environment]::NewLine + '    candidates = sorted(ASSET_DIR.glob(\"*.xlsx\"), key=lambda path: path.name.lower())' + [Environment]::NewLine + '    for path in candidates:' + [Environment]::NewLine + '        if path.name.startswith(\"~$\") or path.stat().st_size < 1024:' + [Environment]::NewLine + '            continue' + [Environment]::NewLine + '        if name_part.lower() in path.name.lower():' + [Environment]::NewLine + '            return path' + [Environment]::NewLine + '    return None'; $updated=[regex]::Replace($text,$pattern,$replacement); if ($updated -eq $text) { throw 'find_asset_workbook regex did not match' }; $utf8NoBom=New-Object System.Text.UTF8Encoding($false); [System.IO.File]::WriteAllText((Resolve-Path $path), $updated, $utf8NoBom)"], decision="allow")
